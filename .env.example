# Signet — copy to .env and fill in your keys
# .env is gitignored; .env.example is the committed template.

# LLM providers — set whichever you have. Demo falls back to mock when missing.
OPENAI_API_KEY=
GEMINI_API_KEY=

# ElevenLabs Scribe STT — for the voice-trigger demo path
ELEVENLABS_API_KEY=

# Verifier
SIGNET_VERIFIER_URL=http://localhost:8000

# Multi-tenant API keys (JSON map of key->tenant_id, or comma-separated for legacy single-tenant)
# SIGNET_API_KEYS={"sk_acme_xxx":"acme","sk_globex_yyy":"globex"}

# Logging / CORS
# SIGNET_LOG_LEVEL=INFO
# SIGNET_CORS_ORIGINS=http://localhost:3000
