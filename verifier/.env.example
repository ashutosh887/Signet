# Signet verifier configuration.
# Copy to verifier/.env and edit as needed.

# How many synthetic samples to use when the anomaly detector trains at boot.
# Lower = faster boot, less stable AUC. Defaults are 120 / 40.
SIGNET_TRAIN_LEGIT=120
SIGNET_TRAIN_ROGUE=40

# Skip training entirely (the verifier still runs; anomaly scoring is disabled).
# Set to 1 only for fast iteration on the crypto path.
SIGNET_SKIP_TRAIN=0

# SQLite envelope log location. Relative to the verifier/ directory.
SIGNET_DB_PATH=signet.db

# Uvicorn log level (debug | info | warning | error).
SIGNET_LOG_LEVEL=info

# Comma-separated CORS allow-list for browser access. Use * for local dev.
SIGNET_CORS_ORIGINS=*
